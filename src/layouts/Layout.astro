---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../index.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Hozaifa Ali - Software Engineer Portfolio" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/vite.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body class="bg-white dark:bg-gray-950 text-gray-900 dark:text-white transition-colors duration-300">
		<slot />
	</body>
</html>
